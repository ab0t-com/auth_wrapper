# === Auth Configuration ===
# These map directly to app/config.py Settings fields.

# Auth service URL — where JWTs are validated and permissions are checked.
AB0T_AUTH_URL=https://auth.service.ab0t.com

# Audience — must match service.audience in .permissions.json.
# Tokens issued for other services will be rejected.
AB0T_AUTH_AUDIENCE=__SERVICE_SLUG__

# Permission check mode:
#   "client" — checks permissions from JWT claims (instant, but may be stale)
#   "server" — checks permissions via API call (5-10ms, instant revocation)
# Always use "server" in production.
AB0T_AUTH_PERMISSION_CHECK_MODE=server

# === Development Only ===
# BOTH must be "true" to enable auth bypass. Defense-in-depth prevents
# accidental production use. Only "true" works — not "1", "yes", etc.
AB0T_AUTH_DEBUG=false
AB0T_AUTH_BYPASS=false

# Optional: customize the bypass user (only applies when bypass is enabled)
# AB0T_AUTH_BYPASS_USER_ID=dev_user
# AB0T_AUTH_BYPASS_EMAIL=dev@localhost
# AB0T_AUTH_BYPASS_PERMISSIONS=__SERVICE_SLUG__:read,__SERVICE_SLUG__:write
# AB0T_AUTH_BYPASS_ROLES=__SERVICE_SLUG__-user
